private void enrichEndpointFromCache(
    String projectRoot,
    FeatureParser.ApiEndpoint ep
) {
    if (
        projectRoot == null
            || projectRoot.isBlank()
            || ep == null
    ) {
        return;
    }

    try {
        /*
         * Localiza o cache principalmente pelo operationId.
         */
        Path cacheFile = findCacheFile(
            projectRoot,
            ep.method,
            ep.path,
            ep.operationId
        );

        if (
            cacheFile == null
                || !Files.isRegularFile(cacheFile)
        ) {
            System.out.println(
                "[API FLOW] Cache não encontrado para: "
                    + ep.operationId
            );
            return;
        }

        String content = Files.readString(
            cacheFile,
            StandardCharsets.UTF_8
        );

        JsonElement parsed = JsonParser.parseString(content);
        JsonObject cacheEntry = null;

        /*
         * Seu cache possui este formato:
         *
         * [
         *   {
         *     "operationId": "...",
         *     "path": { ... }
         *   }
         * ]
         */
        if (parsed.isJsonArray()) {
            JsonArray array = parsed.getAsJsonArray();

            if (
                array.size() > 0
                    && array.get(0).isJsonObject()
            ) {
                cacheEntry = array
                    .get(0)
                    .getAsJsonObject();
            }
        } else if (parsed.isJsonObject()) {
            cacheEntry = parsed.getAsJsonObject();
        }

        if (cacheEntry == null) {
            return;
        }

        /*
         * No seu JSON, method e url ficam dentro de "path".
         */
        JsonObject requestData = cacheEntry;

        if (
            cacheEntry.has("path")
                && cacheEntry.get("path").isJsonObject()
        ) {
            requestData =
                cacheEntry.getAsJsonObject("path");
        }

        /*
         * Atualiza o método do endpoint com o valor real do cache.
         */
        if (
            requestData.has("method")
                && requestData.get("method").isJsonPrimitive()
        ) {
            String cacheMethod =
                requestData.get("method")
                    .getAsString()
                    .trim();

            if (!cacheMethod.isEmpty()) {
                ep.method =
                    cacheMethod.toUpperCase(
                        java.util.Locale.ROOT
                    );
            }
        }

        /*
         * Atualiza o path utilizado no card do fluxo.
         */
        String cacheUrl = "";

        if (
            requestData.has("url")
                && requestData.get("url").isJsonPrimitive()
        ) {
            cacheUrl =
                requestData.get("url")
                    .getAsString()
                    .trim();
        } else if (
            requestData.has("path")
                && requestData.get("path").isJsonPrimitive()
        ) {
            cacheUrl =
                requestData.get("path")
                    .getAsString()
                    .trim();
        }

        if (!cacheUrl.isEmpty()) {
            ep.path = extractRequestPath(cacheUrl);
        }

        System.out.println(
            "[API FLOW] Cache aplicado:"
                + " operationId=" + ep.operationId
                + " | method=" + ep.method
                + " | path=" + ep.path
                + " | file=" + cacheFile
        );

    } catch (Exception e) {
        System.out.println(
            "[API FLOW] Erro ao enriquecer endpoint "
                + ep.operationId
                + ": "
                + e.getMessage()
        );

        e.printStackTrace();
    }
}
