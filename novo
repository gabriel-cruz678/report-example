private void handleLoadCacheJson(JsonElement payload) {
    ApplicationManager.getApplication().invokeLater(() -> {
        try {
            if (payload == null || !payload.isJsonObject()) {
                return;
            }

            JsonObject data = payload.getAsJsonObject();

            String method = data.has("method")
                ? data.get("method").getAsString()
                : "";

            String path = data.has("path")
                ? data.get("path").getAsString()
                : "";

            String operationId = data.has("operationId")
                ? data.get("operationId").getAsString()
                : "";

            String nodeId = data.has("nodeId")
                ? data.get("nodeId").getAsString()
                : "";

            /*
             * Corrige method e path utilizando os dados reais
             * carregados do Swagger.
             */
            SwaggerEndpointInfo swaggerEndpoint =
                swaggerEndpointsByOperationId.get(
                    normalizeOperationId(operationId)
                );

            if (swaggerEndpoint != null) {
                if (
                    swaggerEndpoint.method != null
                        && !swaggerEndpoint.method.isBlank()
                ) {
                    method = swaggerEndpoint.method;
                }

                if (
                    swaggerEndpoint.path != null
                        && !swaggerEndpoint.path.isBlank()
                ) {
                    path = swaggerEndpoint.path;
                }
            }

            String projectRoot = project.getBasePath();

            if (projectRoot == null) {
                return;
            }

            System.out.println(
                "[API FLOW CACHE] operationId="
                    + operationId
                    + " | method="
                    + method
                    + " | path="
                    + path
            );

            /*
             * A busca agora usa somente método e path reais.
             * O operationId não participa da montagem do nome.
             */
            Path cacheFile = findCacheFile(
                projectRoot,
                method,
                path
            );

            /*
             * Cache não encontrado.
             */
            if (
                cacheFile == null
                    || !Files.exists(cacheFile)
            ) {
                System.out.println(
                    "[API FLOW CACHE] Cache não encontrado para: "
                        + method
                        + " "
                        + path
                );

                JsonObject resp = new JsonObject();

                resp.addProperty(
                    "operationId",
                    operationId
                );

                resp.addProperty(
                    "nodeId",
                    nodeId
                );

                resp.addProperty(
                    "found",
                    false
                );

                resp.addProperty(
                    "cacheFilePath",
                    ""
                );

                resp.add(
                    "cacheData",
                    new JsonObject()
                );

                sendToJs(
                    "{ type: 'cacheJsonLoaded', payload: "
                        + resp
                        + " }"
                );

                return;
            }

            System.out.println(
                "[API FLOW CACHE] Cache encontrado: "
                    + cacheFile
            );

            String content = Files.readString(
                cacheFile,
                StandardCharsets.UTF_8
            );

            JsonElement parsed =
                JsonParser.parseString(content);

            JsonObject pathObj = new JsonObject();

            /*
             * Formato mais comum:
             *
             * [
             *   {
             *     "task": "...",
             *     "path": {
             *       "method": "get",
             *       "url": "..."
             *     }
             *   }
             * ]
             */
            if (
                parsed.isJsonArray()
                    && parsed.getAsJsonArray().size() > 0
            ) {
                JsonElement firstElement =
                    parsed.getAsJsonArray().get(0);

                if (firstElement.isJsonObject()) {
                    JsonObject entry =
                        firstElement.getAsJsonObject();

                    if (
                        entry.has("path")
                            && entry.get("path").isJsonObject()
                    ) {
                        pathObj =
                            entry.getAsJsonObject("path");
                    } else {
                        /*
                         * Fallback caso o próprio objeto já seja
                         * o conteúdo do cache.
                         */
                        pathObj = entry;
                    }
                }
            }

            /*
             * Também aceita cache salvo como objeto simples,
             * sem o array externo.
             */
            else if (parsed.isJsonObject()) {
                JsonObject entry =
                    parsed.getAsJsonObject();

                if (
                    entry.has("path")
                        && entry.get("path").isJsonObject()
                ) {
                    pathObj =
                        entry.getAsJsonObject("path");
                } else {
                    pathObj = entry;
                }
            }

            JsonObject resp = new JsonObject();

            resp.addProperty(
                "operationId",
                operationId
            );

            resp.addProperty(
                "nodeId",
                nodeId
            );

            resp.addProperty(
                "found",
                true
            );

            resp.addProperty(
                "cacheFilePath",
                cacheFile.toString()
            );

            resp.add(
                "cacheData",
                pathObj
            );

            sendToJs(
                "{ type: 'cacheJsonLoaded', payload: "
                    + resp
                    + " }"
            );

        } catch (Exception e) {
            e.printStackTrace();

            Messages.showErrorDialog(
                project,
                "Erro ao ler cache: "
                    + e.getMessage(),
                "BEX Automation Flow"
            );
        }
    });
}
