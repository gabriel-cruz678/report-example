private boolean cacheContainsOperationId(
    Path cacheFile,
    String expectedOperationId
) {
    try {
        String content = Files.readString(
            cacheFile,
            StandardCharsets.UTF_8
        );

        JsonElement parsed =
            JsonParser.parseString(content);

        return jsonContainsOperationId(
            parsed,
            expectedOperationId
        );

    } catch (Exception e) {
        System.out.println(
            "[API FLOW CACHE] Ignorando arquivo inválido: "
                + cacheFile
                + " | "
                + e.getMessage()
        );

        return false;
    }
}

private boolean jsonContainsOperationId(
    JsonElement element,
    String expectedOperationId
) {
    if (element == null || element.isJsonNull()) {
        return false;
    }

    if (element.isJsonArray()) {
        for (JsonElement item : element.getAsJsonArray()) {
            if (
                jsonContainsOperationId(
                    item,
                    expectedOperationId
                )
            ) {
                return true;
            }
        }

        return false;
    }

    if (!element.isJsonObject()) {
        return false;
    }

    JsonObject object = element.getAsJsonObject();

    if (
        object.has("operationId")
            && object.get("operationId").isJsonPrimitive()
    ) {
        String cachedOperationId =
            object.get("operationId")
                .getAsString()
                .trim();

        if (
            cachedOperationId.equalsIgnoreCase(
                expectedOperationId
            )
        ) {
            return true;
        }
    }

    /*
     * Também procura em objetos internos, caso futuramente
     * o operationId seja gravado dentro de "path".
     */
    for (
        Map.Entry<String, JsonElement> entry
            : object.entrySet()
    ) {
        if (
            jsonContainsOperationId(
                entry.getValue(),
                expectedOperationId
            )
        ) {
            return true;
        }
    }

    return false;
}

