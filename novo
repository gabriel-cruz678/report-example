private Path findCacheFile(
    String projectRoot,
    String method,
    String pathOrUrl,
    String operationId
) throws IOException {

    Path cacheRoot = Path.of(projectRoot, ".cache");

    if (!Files.isDirectory(cacheRoot)) {
        System.out.println(
            "[API FLOW CACHE] Diretório não encontrado: "
                + cacheRoot
        );
        return null;
    }

    List<Path> jsonFiles = new ArrayList<>();

    try (
        java.util.stream.Stream<Path> stream =
            Files.walk(cacheRoot)
    ) {
        stream
            .filter(Files::isRegularFile)
            .filter(file ->
                file.getFileName()
                    .toString()
                    .toLowerCase(java.util.Locale.ROOT)
                    .endsWith(".json")
            )
            .forEach(jsonFiles::add);
    }

    String expectedOperationId =
        operationId == null
            ? ""
            : operationId.trim();

    /*
     * 1. Busca principal pelo operationId exato.
     */
    if (!expectedOperationId.isEmpty()) {
        List<Path> operationIdMatches =
            new ArrayList<>();

        for (Path cacheFile : jsonFiles) {
            if (
                cacheContainsOperationId(
                    cacheFile,
                    expectedOperationId
                )
            ) {
                operationIdMatches.add(cacheFile);
            }
        }

        if (operationIdMatches.size() == 1) {
            Path found = operationIdMatches.get(0);

            System.out.println(
                "[API FLOW CACHE] Encontrado por operationId: "
                    + expectedOperationId
                    + " -> "
                    + found
            );

            return found;
        }

        /*
         * Caso raro: mais de um arquivo possui o mesmo operationId.
         * Desempata por método e rota.
         */
        if (operationIdMatches.size() > 1) {
            List<Path> exactRequestMatches =
                new ArrayList<>();

            for (Path candidate : operationIdMatches) {
                if (
                    cacheMatchesMethodAndPath(
                        candidate,
                        method,
                        pathOrUrl
                    )
                ) {
                    exactRequestMatches.add(candidate);
                }
            }

            if (exactRequestMatches.size() == 1) {
                Path found = exactRequestMatches.get(0);

                System.out.println(
                    "[API FLOW CACHE] Encontrado por operationId "
                        + "e method/path: "
                        + found
                );

                return found;
            }

            System.out.println(
                "[API FLOW CACHE] operationId ambíguo: "
                    + expectedOperationId
                    + ". Quantidade de arquivos: "
                    + operationIdMatches.size()
            );

            for (Path candidate : operationIdMatches) {
                System.out.println(
                    "[API FLOW CACHE] Candidato: "
                        + candidate
                );
            }

            /*
             * Não escolhe arbitrariamente um arquivo.
             */
            return null;
        }
    }

    /*
     * 2. Fallback para caches antigos sem operationId.
     * Compara exatamente method e path/url.
     */
    List<Path> methodPathMatches =
        new ArrayList<>();

    for (Path cacheFile : jsonFiles) {
        if (
            cacheMatchesMethodAndPath(
                cacheFile,
                method,
                pathOrUrl
            )
        ) {
            methodPathMatches.add(cacheFile);
        }
    }

    if (methodPathMatches.size() == 1) {
        Path found = methodPathMatches.get(0);

        System.out.println(
            "[API FLOW CACHE] Cache antigo encontrado "
                + "por method/path: "
                + found
        );

        return found;
    }

    if (methodPathMatches.size() > 1) {
        System.out.println(
            "[API FLOW CACHE] Busca por method/path ambígua: "
                + normalizeCacheMethod(method)
                + " "
                + normalizeCachePath(pathOrUrl)
        );

        for (Path candidate : methodPathMatches) {
            System.out.println(
                "[API FLOW CACHE] Candidato: "
                    + candidate
            );
        }
    } else {
        System.out.println(
            "[API FLOW CACHE] Cache não encontrado."
                + " operationId="
                + expectedOperationId
                + " | method="
                + normalizeCacheMethod(method)
                + " | path="
                + normalizeCachePath(pathOrUrl)
        );
    }

    return null;
}
