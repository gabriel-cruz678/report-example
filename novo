Entrada:

setFieldRequest_method
setFieldRequest_pathkey
setFieldRequest_pathexpr
setFieldRequest_value

Saída:

{
    operationId: row.setFieldRequest_pathkey.trim(),
    method: row.setFieldRequest_method.trim().toLowerCase(),
    fieldSet: {
