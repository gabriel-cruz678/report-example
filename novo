private String extractRequestPath(String urlOrPath) {
    if (
        urlOrPath == null
            || urlOrPath.isBlank()
    ) {
        return "";
    }

    String value = urlOrPath.trim();

    /*
     * Converte:
     *
     * http://127.0.0.1:8443/automation/v2/disconnect-user
     *
     * em:
     *
     * /automation/v2/disconnect-user
     */
    try {
        if (
            value.startsWith("http://")
                || value.startsWith("https://")
        ) {
            java.net.URI uri =
                java.net.URI.create(value);

            String path = uri.getPath();

            if (
                path != null
                    && !path.isBlank()
            ) {
                return path;
            }
        }
    } catch (IllegalArgumentException ignored) {
        // Continua tratando o conteúdo como um path simples.
    }

    int queryIndex = value.indexOf('?');

    if (queryIndex >= 0) {
        value = value.substring(0, queryIndex);
    }

    int fragmentIndex = value.indexOf('#');

    if (fragmentIndex >= 0) {
        value = value.substring(0, fragmentIndex);
    }

    if (!value.startsWith("/")) {
        value = "/" + value;
    }

    return value;
}
