Exemplo de montagem dos endpoints

A lógica pode ser equivalente a esta:

function applyFeatureFields(endpoints, getRows, setRows) {
    endpoints.forEach(function (endpoint) {
        endpoint.fieldGets = [];
        endpoint.fieldSets = [];

        getRows.forEach(function (row) {
            var operationId = String(
                row.getFieldResponse_pathkey || ''
            ).trim();

            if (operationId !== endpoint.operationId) {
                return;
            }

            endpoint.fieldGets.push({
                nameVar: String(row.name_var || '').trim(),
                expr: String(row.getFieldResponse_expr || '').trim()
            });
        });

        setRows.forEach(function (row) {
            var operationId = String(
                row.setFieldRequest_pathkey || ''
            ).trim();

            if (operationId !== endpoint.operationId) {
                return;
            }

            endpoint.fieldSets.push({
                pathExpr: String(
                    row.setFieldRequest_pathexpr || ''
                ).trim(),

                value: String(
                    row.setFieldRequest_value || ''
                ).trim()
            });
        });
    });

    return endpoints;
}
