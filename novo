private String buildCacheFileName(
    String method,
    String pathOrUrl
) {
    String normalizedMethod =
        normalizeCacheMethod(method);

    String normalizedPath =
        normalizeCachePath(pathOrUrl)
            .replaceAll("\\{[^}]*}", "")
            .replaceAll("[^a-z0-9]+", "_")
            .replaceAll("^_+|_+$", "");

    if (normalizedMethod.isEmpty()) {
        return normalizedPath + ".json";
    }

    return normalizedMethod
        + "_"
        + normalizedPath
        + ".json";
}

private String normalizeCacheMethod(String method) {
    return method == null
        ? ""
        : method.trim().toLowerCase();
}

private String normalizeCachePath(String pathOrUrl) {
    if (pathOrUrl == null || pathOrUrl.isBlank()) {
        return "";
    }

    String value = pathOrUrl.trim();

    try {
        if (
            value.startsWith("http://")
                || value.startsWith("https://")
        ) {
            java.net.URI uri =
                java.net.URI.create(value);

            value = uri.getPath() == null
                ? ""
                : uri.getPath();
        }
    } catch (IllegalArgumentException ignored) {
        /*
         * Se não for uma URL válida, mantém o path
         * original recebido.
         */
    }

    int queryIndex = value.indexOf('?');

    if (queryIndex >= 0) {
        value = value.substring(0, queryIndex);
    }

    int fragmentIndex = value.indexOf('#');

    if (fragmentIndex >= 0) {
        value = value.substring(0, fragmentIndex);
    }

    return value
        .replace('\\', '/')
        .replaceAll("/+$", "")
        .toLowerCase();
}

private boolean cacheFileMatches(
    Path cacheFile,
    String expectedMethod,
    String expectedPathOrUrl
) {
    try {
        String content = Files.readString(
            cacheFile,
            StandardCharsets.UTF_8
        );

        JsonElement parsed =
            JsonParser.parseString(content);

        JsonObject pathObject =
            extractCachePathObject(parsed);

        String cacheMethod =
            pathObject.has("method")
                ? pathObject.get("method").getAsString()
                : "";

        String cacheUrl;

        if (pathObject.has("url")) {
            cacheUrl =
                pathObject.get("url").getAsString();
        } else if (pathObject.has("path")) {
            cacheUrl =
                pathObject.get("path").getAsString();
        } else {
            cacheUrl = "";
        }

        boolean sameMethod =
            normalizeCacheMethod(cacheMethod)
                .equals(
                    normalizeCacheMethod(expectedMethod)
                );

        boolean samePath =
            normalizeCachePath(cacheUrl)
                .equals(
                    normalizeCachePath(expectedPathOrUrl)
                );

        return sameMethod && samePath;

    } catch (Exception ignored) {
        /*
         * Um JSON inválido não deve interromper
         * a busca pelos outros arquivos.
         */
        return false;
    }
}

private JsonObject extractCachePathObject(
    JsonElement parsed
) {
    if (parsed == null || parsed.isJsonNull()) {
        return new JsonObject();
    }

    JsonObject entry = null;

    if (parsed.isJsonArray()) {
        JsonArray array = parsed.getAsJsonArray();

        if (
            array.size() > 0
                && array.get(0).isJsonObject()
        ) {
            entry =
                array.get(0).getAsJsonObject();
        }
    } else if (parsed.isJsonObject()) {
        entry = parsed.getAsJsonObject();
    }

    if (entry == null) {
        return new JsonObject();
    }

    if (
        entry.has("path")
            && entry.get("path").isJsonObject()
    ) {
        return entry.getAsJsonObject("path");
    }

    return entry;
}
