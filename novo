private void handleLoadCacheJson(JsonElement payload) {
    ApplicationManager.getApplication().invokeLater(() -> {
        try {
            if (payload == null || !payload.isJsonObject()) {
                return;
            }

            JsonObject data = payload.getAsJsonObject();

            String method = data.has("method")
                ? data.get("method").getAsString()
                : "";

            String path = data.has("path")
                ? data.get("path").getAsString()
                : "";

            String operationId = data.has("operationId")
                ? data.get("operationId").getAsString()
                : "";

            String nodeId = data.has("nodeId")
                ? data.get("nodeId").getAsString()
                : "";

            /*
             * Corrige method e path usando os dados reais
             * carregados do Swagger.
             */
            SwaggerEndpointInfo swaggerEndpoint =
                swaggerEndpointsByOperationId.get(
                    normalizeOperationId(operationId)
                );

            if (swaggerEndpoint != null) {
                if (
                    swaggerEndpoint.method != null
                        && !swaggerEndpoint.method.isBlank()
                ) {
                    method = swaggerEndpoint.method;
                }

                if (
                    swaggerEndpoint.path != null
                        && !swaggerEndpoint.path.isBlank()
                ) {
                    path = swaggerEndpoint.path;
                }
            }

            String projectRoot = project.getBasePath();

            if (projectRoot == null || projectRoot.isBlank()) {
                return;
            }

            System.out.println(
                "[API FLOW CACHE] operationId=" + operationId
                    + " | method=" + method
                    + " | path=" + path
            );

            /*
             * Mantemos os quatro parâmetros para não quebrar
             * outras chamadas já existentes no projeto.
             */
            Path cacheFile = findCacheFile(
                projectRoot,
                method,
                path,
                operationId
            );

            JsonObject resp = new JsonObject();

            resp.addProperty("operationId", operationId);
            resp.addProperty("nodeId", nodeId);

            if (cacheFile == null || !Files.isRegularFile(cacheFile)) {
                System.out.println(
                    "[API FLOW CACHE] Cache não encontrado: "
                        + method
                        + " "
                        + path
                );

                resp.addProperty("found", false);
                resp.addProperty("cacheFilePath", "");
                resp.add("cacheData", new JsonObject());

                sendToJs(
                    "{ type: 'cacheJsonLoaded', payload: "
                        + resp
                        + " }"
                );

                return;
            }

            System.out.println(
                "[API FLOW CACHE] Cache encontrado: "
                    + cacheFile
            );

            String content = Files.readString(
                cacheFile,
                StandardCharsets.UTF_8
            );

            JsonElement parsed = JsonParser.parseString(content);

            JsonObject cacheData =
                extractCachePathObject(parsed);

            resp.addProperty("found", true);
            resp.addProperty(
                "cacheFilePath",
                cacheFile.toString()
            );
            resp.add("cacheData", cacheData);

            sendToJs(
                "{ type: 'cacheJsonLoaded', payload: "
                    + resp
                    + " }"
            );

        } catch (Exception e) {
            e.printStackTrace();

            Messages.showErrorDialog(
                project,
                "Erro ao ler cache: " + e.getMessage(),
                "BEX Automation Flow"
            );
        }
    });
}
